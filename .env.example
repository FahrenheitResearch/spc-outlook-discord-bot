# Discord webhook destination. Required unless you run with --dry-run.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Alternative to webhook posting, useful when reusing an existing Discord app.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_USERNAME=Fast Severe Outlook Bot

# Fast path. Install nwws-rs and set these to let the runner start NWWS ingest.
# cargo install nwws-rs --features serve
NWWS_USERNAME=
NWWS_PASSWORD=
NWWS_AUTOSTART=0
NWWS_SSE_URLS=http://127.0.0.1:8080/v1/stream?office=KWNS&pil=PTS,http://127.0.0.1:8080/v1/stream?office=KWNS&pil=SWO

# Default is image-only Discord messages. Use "link" for the official SPC page,
# or "short"/"debug" for more text.
SPC_MESSAGE_CONTENT=none

# Default posts four unofficial fast bundles from official NOAA/NWS SPC geometry products.
# Options: custom-first, custom-only, official-only, both.
SPC_RENDER_MODE=custom-only

# Custom geometry source. Production default keeps Day 1-3 on complete official SPC GeoJSON.
# Options: geojson-first, geojson-only, pts-only.
SPC_CUSTOM_SOURCE=geojson-only

# Shrinks custom maps inside the PNG canvas so Discord attachment previews crop less.
# Use 1.0 to disable.
SPC_IMAGE_SAFE_SCALE=0.95

# Optional high-signal mode. "enh" posts Day 1-3 only when the custom categorical
# outlook reaches Enhanced or higher. Keep Day 4-8 on when any 15%/30% area exists.
# Options: any, tstm, mrgl, slgt, enh, mdt, high.
SPC_MIN_RISK_LEVEL=any
SPC_ALWAYS_POST_DAY48=0

# 15-20 seconds is a good fallback cadence. NWWS triggers are immediate.
SPC_POLL_SECONDS=20
SPC_FETCH_ATTEMPTS=4
SPC_TRIGGER_FETCH_ATTEMPTS=12
SPC_FETCH_RETRY_SECONDS=5

# On first startup, prime current products to avoid spamming old maps.
# Set SPC_POST_CURRENT_ON_START=1 to immediately post the current four bundles.
SPC_PRIME_CURRENT_ON_START=1
SPC_POST_CURRENT_ON_START=0

# State and dry-run output paths are relative to this folder.
SPC_STATE_FILE=data/state.json
SPC_DRY_RUN_DIR=data/dry-run
